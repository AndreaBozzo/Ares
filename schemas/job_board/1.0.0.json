{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JobBoard",
  "type": "object",
  "description": "A page that lists multiple job postings (a board / search results page)",
  "properties": {
    "jobs": {
      "type": "array",
      "description": "Every job posting listed on the page",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Job title"
          },
          "department": {
            "type": "string",
            "description": "Team or department"
          },
          "location": {
            "type": "string",
            "description": "Job location (city, country, or Remote)"
          },
          "url": {
            "type": "string",
            "description": "Link to the individual job posting"
          }
        },
        "required": [
          "title"
        ]
      }
    }
  },
  "required": [
    "jobs"
  ]
}
