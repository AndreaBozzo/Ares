{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JobListing",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Job title or position name"
    },
    "company": {
      "type": "string",
      "description": "Hiring company name"
    },
    "location": {
      "type": "string",
      "description": "Job location (city, state/country)"
    },
    "salary_range": {
      "type": "string",
      "description": "Salary range if listed (e.g. $80,000 - $120,000/year)"
    },
    "employment_type": {
      "type": "string",
      "description": "Employment type (e.g. Full-time, Part-time, Contract, Internship)"
    },
    "description": {
      "type": "string",
      "description": "Job description summary"
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of job requirements or qualifications"
    },
    "benefits": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of benefits or perks"
    },
    "posted_date": {
      "type": "string",
      "description": "Date the job was posted"
    },
    "application_url": {
      "type": "string",
      "description": "URL to apply for the job"
    },
    "remote": {
      "type": "boolean",
      "description": "Whether the position is remote-friendly"
    }
  },
  "required": [
    "title",
    "company",
    "location",
    "salary_range",
    "employment_type",
    "description",
    "requirements",
    "benefits",
    "posted_date",
    "application_url",
    "remote"
  ]
}
