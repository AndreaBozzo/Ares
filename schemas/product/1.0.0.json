{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductPage",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "brand": {
      "type": "string",
      "description": "Brand or manufacturer name"
    },
    "price": {
      "type": "string",
      "description": "Price including currency symbol (e.g. $29.99, €19.00)"
    },
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code (e.g. USD, EUR, GBP)"
    },
    "description": {
      "type": "string",
      "description": "Product description or summary"
    },
    "rating": {
      "type": "number",
      "description": "Average rating (e.g. 4.5 out of 5)"
    },
    "review_count": {
      "type": "integer",
      "description": "Number of customer reviews"
    },
    "availability": {
      "type": "string",
      "description": "Stock status (e.g. In Stock, Out of Stock, Pre-order)"
    },
    "image_url": {
      "type": "string",
      "description": "URL of the main product image"
    },
    "category": {
      "type": "string",
      "description": "Product category or department"
    },
    "sku": {
      "type": "string",
      "description": "Product SKU or identifier"
    },
    "url": {
      "type": "string",
      "description": "Canonical URL of the product page"
    }
  },
  "required": [
    "name",
    "brand",
    "price",
    "currency",
    "description",
    "rating",
    "review_count",
    "availability",
    "image_url",
    "category",
    "sku",
    "url"
  ]
}
