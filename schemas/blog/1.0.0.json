{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BlogPage",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the blog post"
    },
    "author": {
      "type": "string",
      "description": "Author or byline of the post"
    },
    "publish_date": {
      "type": "string",
      "description": "Date the post was published"
    },
    "summary": {
      "type": "string",
      "description": "Short summary or lead paragraph of the post"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags or topic labels for the post"
    },
    "hero_image": {
      "type": "string",
      "description": "URL of the post's hero or featured image"
    },
    "url": {
      "type": "string",
      "description": "Canonical URL of the blog post"
    }
  },
  "required": [
    "title",
    "author",
    "publish_date",
    "summary",
    "tags",
    "hero_image",
    "url"
  ]
}
